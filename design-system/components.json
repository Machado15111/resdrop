{
  "meta": {
    "name": "ResDrop Component Library",
    "version": "1.0.0",
    "totalComponents": 30,
    "designPhilosophy": "Every pixel serves a purpose. Remove until it breaks, then add one thing back.",
    "figmaLibrary": "ResDrop / Components"
  },

  "components": [

    {
      "id": 1,
      "name": "Button",
      "category": "Action",
      "figmaPath": "Components / Action / Button",
      "description": "Primary action trigger. Uses bold green to command attention against white surfaces. Generous padding for tap targets.",
      "variants": ["primary", "secondary", "ghost", "danger", "brand-inverse"],
      "sizes": ["sm|32px", "md|40px", "lg|48px", "xl|56px"],
      "states": {
        "default": { "cursor": "pointer" },
        "hover": { "transform": "translateY(-1px)", "shadow": "shadow-md", "bg": "lighter shade" },
        "active": { "transform": "translateY(0)", "shadow": "shadow-xs", "bg": "darker shade" },
        "focus": { "outline": "2px solid green-500", "outlineOffset": "2px" },
        "disabled": { "opacity": 1, "bg": "neutral-100", "text": "neutral-400", "cursor": "not-allowed" },
        "loading": { "icon": "spinner replaces icon or label", "pointer-events": "none" }
      },
      "anatomy": ["leading-icon (optional)", "label", "trailing-icon (optional)", "spinner (loading state)"],
      "specs": {
        "borderRadius": "8px",
        "fontWeight": 600,
        "letterSpacing": "-0.01em",
        "minWidth": "auto (sm) | 120px (md+)",
        "iconGap": "6px (sm) | 8px (md+)",
        "transitionProperty": "all",
        "transitionDuration": "200ms",
        "transitionEasing": "ease-default"
      },
      "accessibility": {
        "role": "button",
        "ariaLabel": "Required when icon-only",
        "ariaDisabled": "true when disabled (prefer over disabled attribute for screen readers)",
        "keyboardTrigger": "Enter or Space",
        "contrastRatio": "4.5:1 minimum (text on bg)"
      },
      "usage": {
        "do": ["One primary button per section", "Verb-first labels: 'Verificar Precos', 'Reservar Agora'", "Use loading state for async actions"],
        "dont": ["Multiple primary buttons competing", "Vague labels like 'Clique aqui'", "Disable without tooltip explaining why"]
      }
    },

    {
      "id": 2,
      "name": "IconButton",
      "category": "Action",
      "figmaPath": "Components / Action / IconButton",
      "description": "Square button containing only an icon. For compact actions in toolbars, cards, and table rows.",
      "variants": ["primary", "secondary", "ghost", "danger"],
      "sizes": ["sm|28px", "md|36px", "lg|44px"],
      "states": {
        "default": {},
