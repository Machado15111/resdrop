      "paddingY": "{primitive.spacing.4}",
      "paddingX": "{primitive.spacing.3}"
    },
    "table": {
      "headerHeight": "44px",
      "rowHeight": "52px",
      "cellPaddingX": "{primitive.spacing.4}",
      "cellPaddingY": "{primitive.spacing.3}",
      "borderRadius": "{primitive.radius.md}"
    }
  },

  "layout": {
    "container": {
      "xs":  { "maxWidth": "100%", "padding": "16px" },
      "sm":  { "maxWidth": "640px", "padding": "16px" },
      "md":  { "maxWidth": "768px", "padding": "24px" },
      "lg":  { "maxWidth": "1024px", "padding": "24px" },
      "xl":  { "maxWidth": "1200px", "padding": "32px" },
      "2xl": { "maxWidth": "1400px", "padding": "32px" }
    },
    "grid": {
      "columns": 12,
      "gutter": "{primitive.spacing.6}",
      "margin": "{primitive.spacing.4}"
    }
  }
}
