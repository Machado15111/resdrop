# ResDrop backend — environment variables (copy to server/.env, never commit real values)

# Database (Supabase/postgres connection string)
DATABASE_URL=

# LiteAPI (Nuitée) — hotel rate data + rebooking
# Sandbox keys start with sand_, production keys with prod_.
# Get it at dashboard.liteapi.travel → paste the same value in Railway → Variables.
LITEAPI_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=ResDrop <notifications@resdrop.app>

# Admin
ADMIN_EMAIL=junior13machadojr@gmail.com
