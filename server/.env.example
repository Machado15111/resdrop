# ResDrop backend — environment variables (copy to server/.env, never commit real values)

# Database (Supabase/postgres connection string)
DATABASE_URL=

# Supabase REST (used by scripts/sync-hotels.js)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Nuitée / LiteAPI ─────────────────────────────────────────
# Server-side only. Sandbox keys start with sand_, production with prod_.
NUITEE_API_KEY_SANDBOX=
NUITEE_API_KEY_PRODUCTION=
NUITEE_ENV=sandbox

# Price Index (paid market-trend feature) — OFF by default, cost-capped.
NUITEE_PRICE_INDEX_ENABLED=false
NUITEE_PRICE_INDEX_GLOBAL_MONTHLY_CAP=50
NUITEE_PRICE_INDEX_COST_USD=0.05
NUITEE_RATE_CACHE_HOURS=24
NUITEE_PRICE_INDEX_CACHE_HOURS=24

# Emergency switch: pause all Nuitée monitoring (free Rates endpoint too)
NUITEE_MONITORING_ENABLED=true

# Legacy alias (still read as a fallback key if the NUITEE_* keys are unset)
LITEAPI_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=ResDrop <notifications@resdrop.app>

# Admin
ADMIN_EMAIL=junior13machadojr@gmail.com

# Monitoring schedule
MONITOR_CHECK_HOURS=06,14,22
